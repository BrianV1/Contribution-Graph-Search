{
  "name": "contribution-graph-search",
  "version": "1.0.0",
  "description": "A robotics-themed pathfinding animation over your GitHub contribution graph. A LIDAR-equipped robot uses A* to escape across your commits, rendered as a self-contained animated SVG.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "tsx src/index.ts",
    "demo": "tsx src/index.ts --demo --out dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/index.ts"
  },
  "keywords": [
    "github",
    "contribution-graph",
    "svg",
    "animation",
    "pathfinding",
    "astar",
    "lidar",
    "robotics",
    "profile-readme"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
